package;

import hxp.*;
import lime.tools.*;
import sys.FileSystem;

using StringTools;

/**
 * Inspired by the Funkin Crew's Project.hxp 
 * I think 🤔 i took a few shitz from somehwere
 */
@:nullSafety class Project extends HXProject
{
	// make into json or smth w a macro to require it?

	/**
	 * Game Title	
	 */
	static final TITLE = "Friday Night Funkin' Astro Engine";

	/**
	 * Game Version (FNF SOURCE, NOT MINE)	
	 */
	static final VERSION = "0.2.8"; // source fnf v

	/**
	 * The executable name.
	 */
	static final EXECUTABLE_FILE = "Astro Engine";

	/**
	 * Games Company	
	 */
	static final COMPANY = "YourFriendOrbl";

	/**
	 * Games Company	
	 */
	static final PACKAGE_NAME = "com.astroeg";

	/**
	 * Games Company	
	 */
	static final MAIN_CLASS:String = "funkin.game.Main";

	/**
	 * Source directories.
	 */
	static final SOURCES_DIR:Array<String> = ["source"];

	/**
	 * Preloader	
	 */
	static final PRELOADER:String = "flixel.system.FlxPreloader"; // You can set your own custom preloader class here or use the default one...

	/**
	 * Pre Compile Script	
	 */
	static final PREBUILD_HX:String = "source/Prebuild.hx";

	/**
	 * Post Compile Script
	 */
	static final POSTBUILD_HX:String = "source/Postbuild.hx";

	/**
	 * Asset path globs to always exclude from asset libraries.
	 */
	static final EXCLUDE_ASSETS:Array<String> = [".*", "cvs", "thumbs.db", "desktop.ini", "*.hash", "*.md"];

	/**
	 * Asset path globs to exclude on web platforms.
	 */
	static final EXCLUDE_ASSETS_WEB:Array<String> = ["*.ogg"];

	/**
	 * Asset path globs to exclude on native platforms.
	 */
	static final EXCLUDE_ASSETS_NATIVE:Array<String> = ["*.mp3"];

	//				    //
	//  COMPILER FLAGS  //
	//				   //

