<!-- TODO: make into hxproj file when ever -->

<?xml version="1.0" encoding="utf-8"?>
<project> 
	<!-- _________________________ Application Settings _________________________ -->

	<!-- To Modders: Change the `packageName` to something like `com.astro.fnf.<MOD_NAME>` or `com.<CUSTOM_NAME>.<MOD_NAME>`  -->
	<app title="Friday Night Funkin' Astro Engine" file="Astro Engine" version="0.2.8" packageName="com.astro" main="funkin.game.Main" company="YourFriendOrbl" />

	<!--Switch Export with Unique ApplicationID and Icon-->
	<set name="APP_ID" value="0x0100f6c013bbc000" />

	<!-- NOTE TO SELF: DISABLE THIS IF ISSUES ARE FOUND -->
	<!-- stable luas PUT AFTER FIRST LINE WITH APP NAME AND ETC -->
	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB"/>

	<!--The flixel preloader is not accurate in Chrome. You can use it regularly if you embed the swf into a html file or you can set the actual size of your file manually at "FlxPreloaderBase-onUpdate-bytesTotal"-->
	<app preloader="flixel.system.FlxPreloader" />

	<!--Minimum without FLX_NO_GAMEPAD: 11.8, without FLX_NO_NATIVE_CURSOR: 11.2-->
	<set name="SWF_VERSION" value="11.8" />

	<define name="x86_BUILD" if="32bits" />

	<!-- _____________________________ ASTRO ENGINE CUSTOMIZATION ____________________________ -->

	<!-- Adds base game files. -->
	<!-- HSCRIPT NEEDS TO BE ENABLED TO USE BASE GAME FILES -->
	<define name="BASE_GAME_FILES" />

	<!-- Shows the loading screen. -->
	<define name="SHOW_LOADING_SCREEN" />

	<!-- <define name="WATERMARK" /> -->

	<!-- Enables astro engine watermarks. -->
	<define name="ASTRO_WATERMARKS"/>

	<!-- Enables astro engine watermarks. -->
	<define name="WINDOW_CUSTOMIZATION" if="desktop"/>
	
	<!-- Shaders Allowed -->
	<define name="SHADERS_ALLOWED" unless="flash"/>
	
	<!-- Enable Mod Support -->
	<define name="MODS_ALLOWED" if="desktop" />

	<!-- Enables Lua Support -->
	<define name="LUA_ALLOWED" if="desktop" />

	<!-- Enables HScript Support -->
	<define name="HSCRIPT_ALLOWED" if="desktop" />

	<!-- Enables Threading support -->
	<define name="THREADING_ALLOWED" />

	<!-- Custom FPS allowed -->
	<define name="CUSTOM_FPS_ALLOWED"/>
 
	<!-- Should the Title Screen xml be used. -->
	<define name="TITLE_SCREEN_XML"/>

	<!-- Multi-threaded loading -->
	<define name="MULTITHREADED_LOADING"/>

	<!-- Should soft coded states be allowed -->
	<define name="SOFTCODED_STATES" if="LUA_ALLOWED || HSCRIPT_ALLOWED"/>

	<!-- Enables FlxAnimate Support -->
	<define name="FLXANIMATE_ALLOWED" />

	<!-- Enables Support For Discord Client Integration -->
	<define name="DISCORD_ALLOWED" if="desktop" unless="html5"/>

	<!-- Disable discord's io thread -->
	<define name="DISCORD_DISABLE_IO_THREAD" if="DISCORD_ALLOWED"/>

	<!-- Enables Achievements -->
	<define name="ACHIEVEMENTS_ALLOWED" />

	<!-- Modified logs -->
	<define name="MODIFIED_LOGS" />

	<!-- Enables the dpi fix thingy (NOTICE: windows based systems only) -->
	<define name="ALLOW_DPI_FIX" if="windows"/>

	<!-- Enables a terminal log prompt on debug builds -->
	<define name="DEBUG_SERVER_ALLOWED" if="debug desktop"/>

	<!-- Checks if "git" is allowed -->
	<define name="GIT_ALLOWED" if="debug"/>

	<!-- Enable global script -->
	<define name="GLOBAL_SCRIPT" if="HSCRIPT_ALLOWED"/>
	<define name="CUSTOM_CLASSES" if="HSCRIPT_ALLOWED" />

	<!-- Enables funkin sound tray -->
	<!-- FUNKIN_SOUNDTRAY's Assets are inside the base game files -->
	<define name="FUNKIN_SOUNDTRAY"/>

	<!-- Remove "officialBuild" to use videos on source mod -->
	<define name="VIDEOS_ALLOWED" if="(windows || linux || android) officialBuild || debug" unless="32bits html5"/>

	<!-- Crash handler -->
	<define name="CRASH_HANDLER" if="desktop release" />

	<!-- <define name="SKIP_SPLASH_SCREEN" /> -->

	<!-- DONT ENABLE THIS -->
	<define name="CHECK_FOR_UPDATES" if="desktop officialBuild"/>

	<!-- Style of the logs | classic, indent, pretty -->
	<define name="message.reporting" value="pretty"/>

	<!-- RuleScript abstract txt file path -->
	<define name="rulescript_abstracts_file_path" value="rulescript/RuleScriptAbstracts.txt" />

	<!--Place custom nodes like icons here (higher priority to override the HaxeFlixel icon)-->
	<assets path='art/icons/iconOG.png' rename='icon.png' if="linux" />
	<icon path="art/icons/icon16.png" size='16'/>
	<icon path="art/icons/icon32.png" size='32'/>
	<icon path="art/icons/icon64.png" size='64'/>
	<icon path="art/icons/iconOG.png"/>

	<!-- ____________________________ Window Settings ___________________________ -->

	<!-- These window settings apply to all targets -->
	<window width="1280" height="720" fps="69" background="#000000" hardware="true" vsync="false" />

	<!-- HTML5-specific -->
	<window if="html5" resizable="true" />

	<!-- Desktop-specific -->
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false"/>

	<!-- Mobile-specific -->
	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0" resizable="false"/>

	<!-- Switch-specific -->
	<window if="switch" orientation="landscape" fullscreen="true" width="0" height="0" resizable="true" />

	<!-- _____________________________ Path Settings ____________________________ -->

	<!-- Source classpath -->
	<classpath name="source" />
	
	<!-- Build directories -->
	<set name="BUILD_DIR" value="export/debug" if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit" if="32bits" />

	<!-- Videos -->
	<assets path="assets/videos" library="videos" if="VIDEOS_ALLOWED"/>

	<!-- Songs -->
	<assets path="assets/songs" library="songs" exclude="*.ogg" if="web"/>
	<assets path="assets/songs" library="songs" exclude="*.mp3" unless="web"/>

	<!-- Shared Assets -->
	<assets path="assets/shared" exclude="*.ogg" if="web"/>
	<assets path="assets/shared" exclude="*.mp3" unless="web"/>

	<!-- Mods -->
	<assets path='mods' embed='false'/>

	<!-- Week Assets -->
	<assets path="assets/week_assets" rename="assets" exclude="*.ogg" if="web"/>
	<assets path="assets/week_assets" rename="assets" exclude="*.mp3" unless="web"/>

	<!-- Embedded Assets -->
	<assets path="assets/embed" rename="assets" exclude="*.ogg" if="web" embed='true'/>
	<assets path="assets/embed" rename="assets" exclude="*.mp3" unless="web" embed='true'/>

	<!-- Linux icon -->
	<assets path='art/icons/iconOG.png' rename='icon.png' if="linux" />

	<section if="BASE_GAME_FILES HSCRIPT_ALLOWED">
		<assets path="assets/base_funkin" rename="assets" exclude="*.ogg" if="web"/>
		<assets path="assets/base_funkin" rename="assets" exclude="*.mp3" unless="web"/>
		<haxelib name="grig.audio" if="BASE_GAME_FILES"/>
		<haxelib name="funkin.vis" if="BASE_GAME_FILES"/>
	</section>

	<assets path='art/readme.txt' rename='do NOT readme.txt' />

	<!-- OpenAL config -->
	<section if="desktop">
		<assets path="alsoft.txt" rename="plugins/alsoft.ini" type="text" if="windows"/>
		<assets path="alsoft.txt" rename="plugins/alsoft.conf" type="text" unless="windows"/>
	</section>

	<!-- Font Path -->
	<assets path="assets/fonts" />

	<!-- _______________________________ Libraries ______________________________ -->

	<!-- HaxeFlixel -->
	<haxelib name="flixel"/>
	<haxelib name="flixel-addons"/>

	<!-- TJSON -->
	<haxelib name="tjson" />

	<!-- Faxe -->
	<haxelib name="faxe" if='switch'/>

	<!-- Lua -->
	<haxelib name="linc_luajit" if="LUA_ALLOWED"/>

	<!-- HScript -->
	<haxelib name="rulescript" if="HSCRIPT_ALLOWED" version="git"/>

	<!-- Hxvlc -->
	<haxelib name="hxvlc" if="VIDEOS_ALLOWED" unless="html5"/>

	<!-- FlxAnimate -->
	<haxelib name="flxanimate" if="FLXANIMATE_ALLOWED"/>

	<!-- Discord API -->
	<haxelib name="hxdiscord_rpc" if="DISCORD_ALLOWED" version="git"/>

	<!-- Debug Sever -->
	<haxelib name="hxcpp-debug-server" if="DEBUG_SERVER_ALLOWED"/>

	<haxedef name="HXC_LIBVLC_LOGGING" if="VIDEOS_ALLOWED DEBUG_SERVER_ALLOWED" />
	<haxedef name="HXVLC_NO_SHARE_DIRECTORY" if="VIDEOS_ALLOWED" />

	<!-- ______________________________ Haxedefines _____________________________ -->

	<!-- A Scripts That Runs Before Compile -->
	<prebuild haxe="source/Prebuild.hx" unless="display"/>
	<postbuild haxe="source/Postbuild.hx" unless="display"/>

	<!--Disable the Flixel core focus lost screen-->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />

	<!-- Show debug traces for hxCodec -->
	<haxedef name="HXC_DEBUG_TRACE" if="debug" />

	<!--Disable the Flixel core debugger. Automatically gets set whenever you compile in release mode!-->
	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<!--Enable this for Nape release builds for a serious performance improvement-->
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

	<!-- Crash Handler -->
	<haxedef name="HXCPP_CHECK_POINTER" if="CRASH_HANDLER" />
	<haxedef name="HXCPP_STACK_LINE" if="CRASH_HANDLER" />
	<haxedef name="HXCPP_STACK_TRACE" if="CRASH_HANDLER" />

	<!-- Disable deprecated warnings -->
	<haxedef name='no-deprecation-warnings' />

	<!--Macro fixes-->
	<haxeflag name="--macro" value="allowPackage('flash')" />
	<haxeflag name="--macro" value="include('my.pack')" />
	
	<!-- HScript Pos -->
	<haxedef name="hscriptPos" if="HSCRIPT_ALLOWED" />

	<haxeflag name="--macro" value="include('funkin')"  if="LUA_ALLOWED || HSCRIPT_ALLOWED"/>
	<haxeflag 
		name="--macro" 
		value="include('flixel', true, ['flixel.addons.editors.spine.*', 'flixel.addons.nape.*', 'flixel.system.macros.*', 'flixel.addons.tile.FlxRayCastTilemap' ])" 
		if="LUA_ALLOWED || HSCRIPT_ALLOWED" 
	/>
	
	<haxeflag name="--macro" value="rulescript.macro.RuleScriptedMacro.init()" if="HSCRIPT_ALLOWED"/>

	<!-- Fixes HXCPP NOT FOUND ERRORS -->
	<haxedef name="NO_PRECOMPILED_HEADERS" if="linux" />
</project>
